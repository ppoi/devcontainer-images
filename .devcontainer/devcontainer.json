{
  "name": "devcontainer-images",
  "build": {
    "dockerfile": "${localWorkspaceFolder}/src/Containerfile",
    "context": "${localWorkspaceFolder}/src/"
  },
  "containerUser": "vscode",
  "features": {
    "./configure": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
      ]
    }
  }
}